generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TournamentStatus {
  DRAFT
  REGISTRATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EventStatus {
  DRAFT
  REGISTRATION
  SEEDING
  IN_PROGRESS
  COMPLETED
}

enum TeamStatus {
  REGISTERED
  WAITLISTED
  WITHDRAWN
  CHECKED_IN
}

enum TeamMemberRole {
  CAPTAIN
  PLAYER
}

enum StageType {
  POOL_PLAY
  ROUND_ROBIN
  SINGLE_ELIM
  DOUBLE_ELIM
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id          String       @id @default(cuid())
  clerkId     String       @unique
  email       String       @unique
  name        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ownedTournaments Tournament[]
  teamMemberships  TeamMember[]
}

// ---------------------------------------------------------------------------
// Tournament & Location
// ---------------------------------------------------------------------------

model Tournament {
  id          String           @id @default(cuid())
  name        String
  description String?
  status      TournamentStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  // [{ place: 1, amount: 500, label: "1st Place" }]
  payouts     Json?
  // [{ platform: "YouTube", url: "https://..." }]
  liveStreams  Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id])
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  events Event[]
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  courts      Court[]
  tournaments Tournament[]
}

model Court {
  id         String   @id @default(cuid())
  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  // "Court 1", "Court A", "Sand Court 3"
  name       String
  // "hardwood", "sand", "grass" — extensible for future sports
  surface    String?
  createdAt  DateTime @default(now())

  eventCourts EventCourt[]
  matches     Match[]
}

// ---------------------------------------------------------------------------
// Events
// ---------------------------------------------------------------------------

model Event {
  id           String      @id @default(cuid())
  tournamentId String
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  // players per team: 2=doubles, 4=quads, 6=sixes
  teamSize     Int
  entryCap     Int?
  status       EventStatus @default(DRAFT)
  // match format
  bestOf              Int  @default(1)
  pointsToWin         Int  @default(25)
  // if null, same as pointsToWin
  pointsToWinLastGame Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  courts        EventCourt[]
  teams         Team[]
  stages        Stage[]
  scheduleItems EventScheduleItem[]
}

// Which courts are allocated to an event
model EventCourt {
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  courtId String
  court   Court  @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@id([eventId, courtId])
}

// ---------------------------------------------------------------------------
// Stages (ordered format steps within an event)
// ---------------------------------------------------------------------------

model Stage {
  id      String    @id @default(cuid())
  eventId String
  event   Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // 1 = first stage played, 2 = second, etc.
  order   Int
  name    String
  type    StageType
  // how many teams advance to the next stage (null = final stage)
  advancementCount Int?
  // complex seeding rules expressed as JSON when advancementCount isn't enough
  advancementRule  Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pools   Pool[]
  matches Match[]

  @@unique([eventId, order])
}

// ---------------------------------------------------------------------------
// Pools (within a POOL_PLAY or ROUND_ROBIN stage)
// ---------------------------------------------------------------------------

model Pool {
  id      String @id @default(cuid())
  stageId String
  stage   Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  // "Pool A", "Pool B"
  name    String

  teams   PoolTeam[]
  matches Match[]
}

model PoolTeam {
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  // seeding order into this pool
  seed   Int?

  @@id([poolId, teamId])
}

// ---------------------------------------------------------------------------
// Teams (event-scoped)
// ---------------------------------------------------------------------------

model Team {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  // overall event seed; updated after each stage
  seed      Int?
  status    TeamStatus @default(REGISTERED)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  members TeamMember[]
  pools   PoolTeam[]

  matchesAsTeam1 Match[] @relation("MatchTeam1")
  matchesAsTeam2 Match[] @relation("MatchTeam2")
  wonMatches     Match[] @relation("MatchWinner")
}

model TeamMember {
  id     String         @id @default(cuid())
  teamId String
  team   Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User           @relation(fields: [userId], references: [id])
  role   TeamMemberRole @default(PLAYER)

  @@unique([teamId, userId])
}

// ---------------------------------------------------------------------------
// Matches & Games
// ---------------------------------------------------------------------------

model Match {
  id      String @id @default(cuid())
  stageId String
  stage   Stage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  // null for bracket matches
  poolId  String?
  pool    Pool?  @relation(fields: [poolId], references: [id])

  // Bracket positioning — null for pool play
  // e.g. "Winners Final", "Losers Round 2", "Semifinal"
  bracketRound    String?
  // slot index within that round (used to wire up next-match progression)
  bracketPosition Int?

  // null = TBD (seeded in after earlier matches complete)
  team1Id String?
  team1   Team?  @relation("MatchTeam1", fields: [team1Id], references: [id])
  team2Id String?
  team2   Team?  @relation("MatchTeam2", fields: [team2Id], references: [id])

  courtId String?
  court   Court? @relation(fields: [courtId], references: [id])

  status          MatchStatus @default(SCHEDULED)
  scheduledTime   DateTime?
  actualStartTime DateTime?

  winnerId String?
  winner   Team?  @relation("MatchWinner", fields: [winnerId], references: [id])

  // Double-elim bracket progression: where winner and loser go next
  nextWinnerMatchId String?
  nextLoserMatchId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  games Game[]
}

// Individual games within a match (for best-of-3/5 formats)
model Game {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  gameNumber Int
  team1Score Int      @default(0)
  team2Score Int      @default(0)
  // references Team.id — not a FK to avoid circular complexity
  winnerId   String?
  completedAt DateTime?

  @@unique([matchId, gameNumber])
}

// ---------------------------------------------------------------------------
// Schedule
// ---------------------------------------------------------------------------

model EventScheduleItem {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  // "Pool Play Begins", "Bracket Starts", "Awards Ceremony"
  label         String
  scheduledTime DateTime
  // updated on the fly when the tournament runs ahead/behind
  actualTime    DateTime?
  // minutes allocated per match slot during this window
  matchDurationMinutes Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
