{
  "name": "volley",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/app",
    "build": "npm run build --workspace=packages/design-system && npm run build --workspace=packages/app",
    "storybook": "npm run storybook --workspace=packages/design-system",
    "test": "npm run test:run --workspaces",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
